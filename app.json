      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f13"
      },
      "package": "com.yourname.finywise",
      "versionCode": 1
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
